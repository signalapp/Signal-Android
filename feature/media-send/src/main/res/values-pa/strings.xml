<?xml version="1.0" encoding="UTF-8"?>
<resources>
  <!-- Dialog title shown when the user tries to leave the image editor with unsaved edits. -->
  <string name="MediaSendDialogs__discard_changes">ਤਬਦੀਲੀਆਂ ਅਣਡਿੱਠੀਆਂ ਕਰਨੀਆਂ ਹਨ?</string>
  <!-- Dialog body explaining that leaving the image editor will discard any edits made to the current photo. -->
  <string name="MediaSendDialogs__youll_lose_any_changes">ਤੁਹਾਡੇ ਵਲੋਂ ਇਸ ਫ਼ੋਟੋੋ ਲਈ ਕੀਤੀਆਂ ਕੋਈ ਵੀ ਤਬਦੀਲੀਆਂ ਖਤਮ ਹੋ ਜਾਣਗੀਆਂ।</string>
  <!-- Confirmation button that discards the user\'s image edits. -->
  <string name="MediaSendDialogs__discard">ਖਾਰਜ ਕਰੋ</string>
</resources>
