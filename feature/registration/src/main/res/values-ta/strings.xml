    <!-- Subtitle for the backup folder/file option cards -->
    <string name="ArchiveRestoreSelectionScreen__choose_a_backup_youve_saved">நீங்கள் சேமித்த காப்புப்பிரதியைத் தேர்வு செய்யுங்கள்</string>
