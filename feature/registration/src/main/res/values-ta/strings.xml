    <!-- Contacts permission row title -->
    <string name="GrantPermissionsFragment__contacts">தொடர்புகள்</string>
    <!-- Contacts permission row description -->
    <string name="GrantPermissionsFragment__find_people_you_know">உங்களுக்குத் தெரிந்தவர்களைக் கண்டறியவும். உங்கள் தொடர்புகள் குறியாக்கம் செய்யப்பட்டுள்ளது, மேலும் Signal சேவைக்குக் காண்பிக்கப்படாது.</string>
    <!-- Phone calls permission row title -->
    <string name="GrantPermissionsFragment__phone_calls">ஃபோன் அழைப்புகள்</string>
    <!-- Phone calls permission row description -->
    <string name="GrantPermissionsFragment__make_registering_easier">பதிவுசெய்தலை எளிதாக்கி கூடுதல் அழைப்பு அம்சங்களை செயல்படுத்தலாம்.</string>
    <!-- Storage permission row title -->
    <string name="GrantPermissionsFragment__storage">சேமிப்பகம்</string>
