    <!-- VerificationCodeScreen -->
    <!-- Title of the verification code entry screen -->
    <string name="VerificationCodeScreen__verification_code">சரிபார்ப்புக் குறியீடு</string>
    <!-- Subtitle explaining where the code was sent. Placeholder is the phone number -->
    <string name="VerificationCodeScreen__enter_the_code_we_sent_to_s">நாங்கள் அனுப்பிய குறியீட்டை %1$s க்கு உள்ளிடவும்</string>
    <!-- Button text for wrong number action -->
    <string name="VerificationCodeScreen__wrong_number">தவறான எண்?</string>
    <!-- Button text for resend SMS action -->
    <string name="VerificationCodeScreen__resend_code">குறியீட்டை மீண்டும் அனுப்பு</string>
    <!-- Button text for call me action -->
    <string name="VerificationCodeScreen__call_me_instead">அதற்குப் பதிலாக என்னை அழைக்கவும்</string>
    <!-- Countdown text shown below the resend code button. Placeholders are minutes and seconds -->
    <string name="VerificationCodeScreen__countdown_format">(%1$02d:%2$02d)</string>
    <!-- Button text for call me when countdown is active. Placeholders are minutes and seconds -->
    <string name="VerificationCodeScreen__call_me_available_in">என்னை அழைக்கவும் (%1$02d:%2$02d)</string>
    <!-- Toast shown when the user enters an incorrect verification code -->
    <string name="VerificationCodeScreen__incorrect_code">தவறான குறியீடு</string>
    <!-- Snackbar shown when there is a network error -->
    <string name="VerificationCodeScreen__network_error">இணைக்க முடியவில்லை. உங்கள் நெட்வொர்க்கைச் சரிபார்த்துவிட்டு மீண்டும் முயற்சிக்கவும்.</string>
    <!-- Snackbar shown when rate limited. Placeholder is the retry duration -->
    <string name="VerificationCodeScreen__too_many_attempts_try_again_in_s">அதிக அளவிலான முயற்சிகள். %1$s-இல் மீண்டும் முயலுங்கள்.</string>
    <!-- Snackbar shown for generic/unknown errors -->
    <string name="VerificationCodeScreen__an_unexpected_error_occurred">எதிர்பாராத பிழை ஏற்பட்டது. மீண்டும் முயலுங்கள்.</string>
    <!-- Snackbar shown when we are unable to send an SMS to the user\'s number -->
    <string name="VerificationCodeScreen__unable_to_send_sms">We are unable to send an SMS to your number. Please try again in several hours.</string>
    <!-- Snackbar shown when the selected transport (SMS/voice) is unavailable -->
    <string name="VerificationCodeScreen__could_not_send_code_via_selected_method">தேர்ந்தெடுக்கப்பட்ட முறையின் வழியாகக் குறியீட்டை அனுப்ப முடியவில்லை. வேறொரு விருப்பத்தேர்வை முயற்சிக்கவும்.</string>
    <!-- Snackbar shown for registration errors -->
    <string name="VerificationCodeScreen__registration_error">பதிவுசெய்தல் தோல்வியடைந்தது. மீண்டும் முயலுங்கள்.</string>
    <!-- Button text for having trouble with verification -->
    <string name="VerificationCodeScreen__having_trouble">சிக்கல் உள்ளதா?</string>

