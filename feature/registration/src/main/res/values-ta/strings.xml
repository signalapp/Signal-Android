    <!-- ArchiveRestoreSelectionScreen -->
    <!-- Title text for the archive restore selection screen -->
    <string name="ArchiveRestoreSelectionScreen__restore_or_transfer_account">கணக்கை மீட்டெடுக்கவும் அல்லது இடமாற்றவும்</string>
    <!-- Subtitle text for the archive restore selection screen -->
    <string name="ArchiveRestoreSelectionScreen__subheading">உங்கள் மெசேஜ் வரலாறு மற்றும் கணக்குத் தரவை எவ்வாறு மீட்டெடுக்க விரும்புகிறீர்கள் என்பதைத் தேர்ந்தெடுங்கள்.</string>
    <!-- Title for the Signal Backups option card -->
    <string name="ArchiveRestoreSelectionScreen__from_signal_backups">சிக்னல் காப்புப்பிரதிகளில் இருந்து</string>
    <!-- Subtitle for the Signal Backups option card -->
    <string name="ArchiveRestoreSelectionScreen__your_free_or_paid_signal_backup_plan">உங்கள் இலவச அல்லது கட்டண சிக்னல் காப்புப்பிரதி திட்டம்</string>
